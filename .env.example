# Sao chép thành .env hoặc set biến môi trường trước khi chạy

# --- Local TEST (mặc định appsettings.json: Runtime.Environment = Test) ---
GEMINI_API_KEY=your-gemini-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Production Reviewed (clone project 1 — consumer RabbitMQ) ---
# DOTNET_ENVIRONMENT=Production
# Runtime__Environment=Production
# Runtime__WorkerMode=Reviewed
# RabbitMq__HostName=103.163.216.115
# RabbitMq__VirtualHost=/
# RabbitMq__UserName=web_push
# RabbitMq__Password=your-rabbitmq-password
# RabbitMq__Port=5672
# RabbitMq__QueueName=PROCESS_REVIEW_BANNER_DFP
# RabbitMq__PublishExecutePlanAfterMongoInsert=true
# GamReview__BotIndex=bot_review|1
# Selenium__UserDataDirs=D:\Login\review_profile
# Selenium__Headless=true

# --- Production ExecutePlan (clone project 2 — copy appsettings.Production.ExecutePlan.example.json → Production.json) ---
# DOTNET_ENVIRONMENT=Production
# Runtime__WorkerMode=ExecutePlan
# RabbitMq__ExecutePlanQueueName=PROCESS_EXECUTE_PLAN_DFP
# RabbitMq__PublishExecutePlanAfterMongoInsert=false
# GamReview__BotIndex=bot_execute_plan|1
# Selenium__UserDataDirs=D:\Login\execute_plan_profile

# --- Tesseract OCR tiếng Việt (tải vie.traineddata + eng.traineddata vào tessdata/) ---
# Florence__EnableTesseract=true
# Florence__TesseractLanguages=vie+eng

# --- Keyword API (EN + VI) — bật khi có endpoint ---
# KeywordApi__Enabled=true
# KeywordApi__BaseUrl=https://your-api.example.com
# KeywordApi__KeywordsEndpoint=/api/banner-keywords

# --- MongoDB (giống CONSUMMER_SIS_REPORT: ConnectionMongo + MongoCatalog) ---
# Mongo__Enabled=true
# Mongo__ConnectionString=mongodb://localhost:27017
# Mongo__Database=news_fptonline
# Mongo__CollectionBannerReview=banner_review_log
